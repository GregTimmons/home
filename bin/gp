#!/bin/bash

# gp - git push with automatic upstream prompt and protected branch warning

branch=$(git branch --show-current)

# Check for protected branches
protected_branches="main master develop development stage staging"
for protected in $protected_branches; do
    if [ "$branch" = "$protected" ]; then
        echo "Warning: You're about to push to '$branch'"
        read -p "Are you sure? [y/N] " response
        case "$response" in
            [yY]|[yY][eE][sS])
                ;;
            *)
                echo "Push cancelled."
                exit 1
                ;;
        esac
        break
    fi
done

# Attempt push
output=$(git push 2>&1)
exit_code=$?

if [ $exit_code -eq 0 ]; then
    echo "$output"
    exit 0
fi

# Check if the error is about no upstream branch
if echo "$output" | grep -q "has no upstream branch"; then
    echo "Branch '$branch' has no upstream."
    read -p "Create upstream and push? [Y/n] " response
    
    case "$response" in
        [nN]|[nN][oO])
            echo "Push cancelled."
            exit 1
            ;;
        *)
            git push --set-upstream origin "$branch"
            ;;
    esac
else
    # Some other error, just print it
    echo "$output"
    exit $exit_code
fi
